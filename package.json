{
  "name": "the-foundry",
  "version": "1.1.1",
  "description": "An autonomous multi-agent creative system that builds, writes, composes, and creates indefinitely.",
  "author": "Nicolas Corder",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ndcorder/the-foundry.git"
  },
  "homepage": "https://github.com/ndcorder/the-foundry",
  "keywords": [
    "ai",
    "multi-agent",
    "creative-ai",
    "autonomous",
    "generative-art",
    "portfolio"
  ],
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "foundry": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "prompts/",
    "config/",
    "identity/manifesto.md",
    "stimuli/skills/",
    "stimuli/stimuli.yml",
    "site/src/",
    "site/astro.config.mjs",
    "site/package.json",
    "site/tsconfig.json",
    "site/showcase.yml",
    ".github/"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dashboard": "tsx dashboard/server.ts",
    "lineage": "tsx -e 'import{buildLineageGraph,saveLineageGraph}from\"./src/lineage/index.js\";const g=await buildLineageGraph();await saveLineageGraph(g);console.log(g.nodes.length+\" nodes, \"+g.edges.length+\" edges, \"+g.constellations.length+\" constellations\")'"
  },
  "dependencies": {
    "@earendil-works/gondolin": "^0.10.0",
    "@earendil-works/pi-agent-core": "^0.75.0",
    "@earendil-works/pi-ai": "^0.75.0",
    "outputguard": "^2.1.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.6"
  }
}
