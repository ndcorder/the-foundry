---
interface Props {
  data: { iteration: number; rating: number }[];
}

const { data } = Astro.props;

const width = 300;
const height = 60;
const padding = 4;
const maxRating = 5;
const minRating = Math.min(...data.map(d => d.rating), 3);

const points = data.map((d, i) => {
  const x = padding + (i / (data.length - 1)) * (width - padding * 2);
  const y = height - padding - ((d.rating - minRating) / (maxRating - minRating)) * (height - padding * 2);
  return `${x},${y}`;
}).join(' ');
---

{data.length > 1 && (
  <svg viewBox={`0 0 ${width} ${height}`} class="w-full max-w-xs h-auto" preserveAspectRatio="none">
    <polyline
      points={points}
      fill="none"
      stroke="var(--domain-poetry)"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    {data.map((d, i) => {
      const x = padding + (i / (data.length - 1)) * (width - padding * 2);
      const y = height - padding - ((d.rating - minRating) / (maxRating - minRating)) * (height - padding * 2);
      return <circle cx={x} cy={y} r="3" fill="var(--domain-poetry)" opacity="0.7" />;
    })}
  </svg>
)}
