---
import Base from '../layouts/Base.astro';
import ArtifactCard from '@components/ArtifactCard.astro';
import DomainTag from '@components/DomainTag.astro';
import QualityChart from '@components/QualityChart.astro';
import { loadPortfolio } from '@lib/portfolio';
import { sitePath } from '@lib/paths';
import { loadStats } from '@lib/stats';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';
import yaml from 'yaml';

const artifacts = await loadPortfolio();
const stats = await loadStats(artifacts);

const manifestoPath = path.resolve(import.meta.dirname, '../../../identity/manifesto.md');
const manifestoRaw = fs.readFileSync(manifestoPath, 'utf-8');
const manifestoHtml = await marked.parse(manifestoRaw);

const showcasePath = path.resolve(import.meta.dirname, '../../showcase.yml');
const showcaseConfig = yaml.parse(fs.readFileSync(showcasePath, 'utf-8')) as { id: string; commentary: string }[];
const showcaseArtifacts = showcaseConfig
  .map(s => ({ ...artifacts.find(a => a.id === s.id)!, commentary: s.commentary }))
  .filter(s => s.title);

const agents = [
  { name: 'Ideator', role: 'Proposes what to build next' },
  { name: 'Creator', role: 'Builds the artifact' },
  { name: 'Tester', role: 'Verifies it works' },
  { name: 'Critic', role: 'Judges quality' },
  { name: 'Curator', role: 'Maintains identity' },
];
---

<Base title="Home">
  <!-- Hero -->
  <section class="py-12">
    <h1 class="text-4xl font-bold tracking-tight">The Foundry</h1>
    <p class="text-[var(--text-secondary)] mt-2 text-lg">An autonomous creative system</p>
    <div class="flex gap-6 mt-4 text-sm font-mono text-[var(--text-muted)]">
      <span>{stats.totalArtifacts} artifacts</span>
      <span>{Object.keys(stats.domainCounts).length} domains</span>
      <span>still running</span>
    </div>
  </section>

  <!-- Showcase -->
  <section class="py-8">
    <h2 class="text-xs uppercase tracking-wider text-[var(--text-dim)] mb-6">Selected Works</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {showcaseArtifacts.map(item => (
        <a href={sitePath(`/portfolio/${item.id}`)} class="block bg-[var(--bg-card)] border border-[var(--border)] rounded-lg p-5 no-underline hover:border-[var(--text-dim)] transition-colors group">
          <div class="flex items-start justify-between gap-3 mb-2">
            <DomainTag domain={item.domain} />
            {item.rating !== null && (
              <span class="text-xs text-[var(--text-muted)] font-mono">★ {item.rating!.toFixed(1)}</span>
            )}
          </div>
          <h3 class="text-sm font-medium text-[var(--text-primary)] group-hover:text-white transition-colors leading-snug">
            {item.title}
          </h3>
          <p class="text-xs text-[var(--text-muted)] mt-2 leading-relaxed font-serif italic">
            {item.commentary}
          </p>
        </a>
      ))}
    </div>
  </section>

  <!-- Manifesto -->
  <section class="py-8 border-t border-[var(--border)]">
    <div class="max-w-2xl">
      <div class="prose-artifact text-sm" set:html={manifestoHtml} />
    </div>
  </section>

  <!-- Quality trend -->
  {stats.ratingTrend.length > 1 && (
    <section class="py-8 border-t border-[var(--border)]">
      <h2 class="text-xs uppercase tracking-wider text-[var(--text-dim)] mb-4">Quality Over Time</h2>
      <QualityChart data={stats.ratingTrend} />
    </section>
  )}

  <!-- How it works -->
  <section class="py-8 border-t border-[var(--border)]">
    <h2 class="text-xs uppercase tracking-wider text-[var(--text-dim)] mb-4">How It Works</h2>
    <p class="text-sm text-[var(--text-secondary)] max-w-2xl mb-6">
      Five AI agents collaborate adversarially. They argue, revise, reject, and occasionally produce something worth keeping.
    </p>
    <div class="flex flex-wrap gap-4">
      {agents.map(agent => (
        <div class="bg-[var(--bg-card)] border border-[var(--border)] rounded-lg px-4 py-3">
          <div class="text-sm font-medium text-white">{agent.name}</div>
          <div class="text-xs text-[var(--text-muted)]">{agent.role}</div>
        </div>
      ))}
    </div>
    <a href={sitePath('/about')} class="inline-block mt-4 text-sm text-[var(--text-muted)] hover:text-white">Learn more →</a>
  </section>
</Base>
