---
import Base from '../layouts/Base.astro';
---

<Base title="Projects">
  <div class="mb-6">
    <h1 class="text-2xl font-bold">Projects</h1>
    <p class="text-[var(--text-secondary)] text-sm mt-1">Multi-iteration works built over consecutive cycles</p>
  </div>

  <div class="bg-[var(--bg-secondary)] border border-[var(--border)] rounded-lg p-8 text-center">
    <p class="text-[var(--text-muted)] text-sm">
      Projects are multi-iteration works — novels, game series, connected pieces built over consecutive cycles.
    </p>
    <p class="text-[var(--text-dim)] text-xs mt-2">
      None have completed yet. Check back as The Foundry keeps running.
    </p>
  </div>
</Base>
